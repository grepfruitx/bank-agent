DATABASE_URL=dbname=ragdb user=postgres password=postgres host=localhost port=5432

# LLM/эмбеддинги — любой OpenAI-совместимый провайдер (OpenRouter, OpenAI, локальный vLLM и т.п.)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-...
LLM_MODEL=anthropic/claude-sonnet-5
EMBED_MODEL=nvidia/nemotron-3-embed-1b:free

# управление reasoning-режимом (актуально для reasoning-моделей типа gpt-oss —
# без этого они долго "думают" перед ответом, отсюда задержка в десятки секунд).
# Оба параметра необязательные — если не заданы, ничего не отправляется в API
# и обычные (не-reasoning) модели работают как обычно.
# LLM_REASONING_ENABLED: true/false — полностью включить/выключить reasoning
# LLM_REASONING_EFFORT: low/medium/high — если модель не поддерживает enabled=false,
#   можно урезать глубину рассуждений вместо полного отключения
LLM_REASONING_ENABLED=false
LLM_REASONING_EFFORT=low
